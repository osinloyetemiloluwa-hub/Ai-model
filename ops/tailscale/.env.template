# CorvinOS — Tailscale deployment env-template
#
# Copy to ops/tailscale/.env, fill in, then:
#   docker compose -f ops/tailscale/docker-compose.yml --env-file ops/tailscale/.env up -d
#
# This file should be mode 0600 and NEVER committed.

# ── Tailscale ─────────────────────────────────────────────────────────
# Required. Generate at:
#   https://login.tailscale.com/admin/settings/keys
# Recommended flags when creating the key:
#   - Reusable: NO   (one container = one key — easier to rotate)
#   - Ephemeral: NO  (so the device persists across `docker compose down`)
#   - Tagged: YES, e.g. `tag:corvin-server` (lets you use ACLs later)
TS_AUTHKEY=tskey-auth-CHANGEME

# Optional — overrides the tailnet hostname (default: "corvin").
# Use this if you already have an "corvin" device on your tailnet.
# CORVIN_TS_HOSTNAME=corvin-prod

# Optional — extra flags appended to `tailscale up`. Defaults already
# include --accept-routes. Examples:
#   TS_EXTRA_ARGS=--advertise-exit-node --ssh
# TS_EXTRA_ARGS=

# ── CorvinOS ─────────────────────────────────────────────────────────
# Image tag. Pin to a published version in production; latest is fine
# for the first try.
CORVIN_IMAGE=ghcr.io/veegee82/corvinos:latest

# Single-operator default. Leave as _default unless you actually want
# multi-tenant separation.
CORVIN_TENANT_ID=_default

# Where the persistent state lives on the host. Anything that should
# survive `docker compose down` lives under this directory.
CORVIN_DATA_DIR=./data/home

# Memory cap. Corvin + claude subprocesses comfortably fit in 4 GB
# for one operator. Raise if you enable many bridges.
CORVIN_MEM_LIMIT=4G

CORVIN_LOG_LEVEL=INFO

# ── Engine + voice credentials ────────────────────────────────────────
# Anthropic key for the Claude engine. Get from:
#   https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI key for TTS + Whisper STT.
OPENAI_API_KEY=

# ── Bridge toggles (opt-in) ───────────────────────────────────────────
# Set to "true" + drop the matching settings.json into the bind-mounted
# home to enable a bridge. See ops/README.md for details.
CORVIN_BRIDGE_TELEGRAM=false
CORVIN_BRIDGE_DISCORD=false
CORVIN_BRIDGE_WHATSAPP=false
CORVIN_BRIDGE_SLACK=false
CORVIN_BRIDGE_EMAIL=false
