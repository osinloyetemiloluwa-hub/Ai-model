# CorvinOS Docker — Example .env Configuration
#
# Copy this to /opt/corvin/.env and fill in your values.
# IMPORTANT: Keep this file private (chmod 0600) — it contains API keys.

# ═══════════════════════════════════════════════════════════════════════════
# Image Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Use the public release image (most users)
CORVIN_IMAGE=ghcr.io/veegee82/corvinos:latest

# Or use a local build (if you run: docker build -t corvin:dev -f ops/Dockerfile .)
# CORVIN_IMAGE=corvin:dev

# ═══════════════════════════════════════════════════════════════════════════
# Tenant Identity (ADR-0007)
# ═══════════════════════════════════════════════════════════════════════════

# Unique ID per deployment. Each tenant has its own audit chain, workspace,
# roles, consent, and quota. Never reuse IDs across different hosts.
# Default "_default" is fine for single-instance deployments.
CORVIN_TENANT_ID=_default

# ═══════════════════════════════════════════════════════════════════════════
# REQUIRED: API Keys
# ═══════════════════════════════════════════════════════════════════════════

# Anthropic Claude API key
# Get from: https://console.anthropic.com/keys
# Format: sk-ant-v0-...
# REQUIRED for the adapter to work at all.
ANTHROPIC_API_KEY=sk-ant-v0-YOUR_KEY_HERE

# OpenAI API key (optional)
# Required only if:
#   - Using Whisper for speech-to-text transcription
#   - Using OpenAI TTS for voice output
# If not set, voice features use alternative providers (if configured).
# Get from: https://platform.openai.com/account/api-keys
# Format: sk-org-...
OPENAI_API_KEY=sk-org-YOUR_KEY_HERE

# ═══════════════════════════════════════════════════════════════════════════
# TLS / HTTPS Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Option 1: Let's Encrypt (production, requires public domain)
#   Set CORVIN_DOMAIN to your domain (must have A-record → this host)
#   Caddy auto-provisions a cert
#
# Option 2: Self-signed (development, testing)
#   Leave CORVIN_DOMAIN empty
#   Use the pre-generated cert at tls/cert.pem + cert.key
#   Browser will show "untrusted" warning (normal for self-signed)
#
# Option 3: Bring your own cert
#   Leave CORVIN_DOMAIN empty
#   Place cert.pem + cert.key in /opt/corvin/tls/
#   Caddy will use them

# PUBLIC DOMAIN: set to your domain (e.g., corvin.example.com)
# Leave empty to use self-signed cert on localhost
CORVIN_DOMAIN=

# Let's Encrypt email (only needed if CORVIN_DOMAIN is set)
# Used for cert renewal reminders, etc.
CORVIN_ACME_EMAIL=

# ═══════════════════════════════════════════════════════════════════════════
# Bridge Toggles (all opt-in, default off)
# ═══════════════════════════════════════════════════════════════════════════

# Discord — requires TOKEN in /opt/corvin/bridge-settings/discord.json
CORVIN_BRIDGE_DISCORD=false

# Telegram — requires TOKEN in /opt/corvin/bridge-settings/telegram.json
CORVIN_BRIDGE_TELEGRAM=false

# WhatsApp — requires QR-pairing on first start
# (check `docker logs corvin` for QR-code)
CORVIN_BRIDGE_WHATSAPP=false

# Slack — requires TOKEN in /opt/corvin/bridge-settings/slack.json
CORVIN_BRIDGE_SLACK=false

# Email bridge (IMAP/SMTP)
CORVIN_BRIDGE_EMAIL=false

# ═══════════════════════════════════════════════════════════════════════════
# Gateway & REST API
# ═══════════════════════════════════════════════════════════════════════════

# Enable the REST API gateway (ADR-0007 Phase 2)
# Provides /v1/runs, /v1/console webhooks, etc. for programmatic access
# The console UI always runs on :8000 regardless
CORVIN_GATEWAY_ENABLED=false

# ═══════════════════════════════════════════════════════════════════════════
# Storage & Directories
# ═══════════════════════════════════════════════════════════════════════════

# Bind-mount location for persistent state
# Inside container: /home/corvin
# On host: this directory
# Recommendation: /opt/corvin/home (default)
CORVIN_DATA_DIR=/opt/corvin/home

# Location of bridge settings (Discord token, Telegram token, etc.)
# Each daemon reads its JSON file from here at startup + on every message
# Recommendation: /opt/corvin/bridge-settings (default)
CORVIN_BRIDGE_SETTINGS_DIR=/opt/corvin/bridge-settings

# Optional: TLS certificates directory
# Only used if CORVIN_DOMAIN is empty (self-signed or custom certs)
CORVIN_TLS_DIR=/opt/corvin/tls

# ═══════════════════════════════════════════════════════════════════════════
# Resource Limits
# ═══════════════════════════════════════════════════════════════════════════

# Maximum RAM the container can use
# Minimum: 1G (tight, not recommended)
# Comfortable: 4G
# Adjust based on your host's available memory
CORVIN_MEM_LIMIT=4G

# ═══════════════════════════════════════════════════════════════════════════
# Logging & Debugging
# ═══════════════════════════════════════════════════════════════════════════

# Enable debug logging (0 = off, 1 = on)
# Produces verbose logs for troubleshooting
CORVIN_DEBUG=0

# Log level (DEBUG, INFO, WARNING, ERROR)
CORVIN_LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════════════════
# Examples: Complete Minimal Setups
# ═══════════════════════════════════════════════════════════════════════════

# SETUP A: Solo user, Claude only, self-signed cert
# ────────────────────────────────────────────────────────────────────────────
# CORVIN_IMAGE=ghcr.io/veegee82/corvinos:latest
# CORVIN_TENANT_ID=_default
# ANTHROPIC_API_KEY=sk-ant-v0-YOUR_KEY
# CORVIN_DOMAIN=
# CORVIN_ACME_EMAIL=
# (no bridges enabled)
#
# Access: http://localhost:8765/console/

# SETUP B: Team deployment with Discord, public domain, Let's Encrypt
# ────────────────────────────────────────────────────────────────────────────
# CORVIN_IMAGE=ghcr.io/veegee82/corvinos:latest
# CORVIN_TENANT_ID=_default
# ANTHROPIC_API_KEY=sk-ant-v0-YOUR_KEY
# OPENAI_API_KEY=sk-org-YOUR_KEY  (for voice TTS)
# CORVIN_DOMAIN=corvin.example.com
# CORVIN_ACME_EMAIL=admin@example.com
# CORVIN_BRIDGE_DISCORD=true
# CORVIN_MEM_LIMIT=8G
#
# Pre-setup: Create /opt/corvin/bridge-settings/discord.json with token + whitelist
# Access: https://corvin.example.com/console/

# SETUP C: Multi-team (two separate instances, different domains)
# ────────────────────────────────────────────────────────────────────────────
# (In two separate directories with their own .env files)
#
# Instance 1:
#   CORVIN_TENANT_ID=team-alpha
#   CORVIN_DOMAIN=corvin-alpha.example.com
#   docker compose -f /opt/corvin-alpha/docker-compose.yml up -d
#
# Instance 2:
#   CORVIN_TENANT_ID=team-bravo
#   CORVIN_DOMAIN=corvin-bravo.example.com
#   docker compose -f /opt/corvin-bravo/docker-compose.yml up -d
#
# Each has independent audit, workspace, roles, quota.
