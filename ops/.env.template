# CorvinOS operator environment — copy to /opt/corvin/.env and fill in.
#
# This file lives outside the repository. Never commit a populated copy.
# Permissions on the deployed file must be 0600.

# ── image ────────────────────────────────────────────────────────────────
# Default pulls the public release. For local builds set to corvin:dev.
CORVIN_IMAGE=ghcr.io/veegee82/corvinos:latest

# ── tenant identity ──────────────────────────────────────────────────────
# Use a unique id per deployment. The migrate helper creates the tree
# on first start. ADR-0007 says: never collide tenants across hosts.
CORVIN_TENANT_ID=_default

# ── public address (Caddy / Let's Encrypt) ──────────────────────────────
# A-record must already resolve to this host before first start.
# Leave CORVIN_DOMAIN empty to fall back to self-signed.
CORVIN_DOMAIN=
CORVIN_ACME_EMAIL=

# ── credentials (loaded into container env, NEVER baked into image) ─────
# Anthropic — either an API key OR a mounted ~/.claude/.credentials.json.
# If both are set the API key wins.
ANTHROPIC_API_KEY=

# OpenAI — required for STT (Whisper API) and TTS unless local providers
# are configured separately.
OPENAI_API_KEY=

# ── bridge toggles (true/false) ─────────────────────────────────────────
# Each bridge also needs its settings.json populated under
# /opt/corvin/home/.config/corvin-voice/ or
# /opt/corvin/home/<repo>/operator/bridges/<channel>/settings.json
# (operator's choice — both paths are picked up).
CORVIN_BRIDGE_TELEGRAM=false
CORVIN_BRIDGE_DISCORD=false
CORVIN_BRIDGE_WHATSAPP=false
CORVIN_BRIDGE_SLACK=false
CORVIN_BRIDGE_EMAIL=false

# ADR-0007 REST gateway. Off by default; flip on if the deployment exposes
# a programmatic API (Kubernetes, multi-machine fleet, etc.).
CORVIN_GATEWAY_ENABLED=false

# ── runtime tuning ──────────────────────────────────────────────────────
CORVIN_DATA_DIR=/opt/corvin/home
CORVIN_MEM_LIMIT=4G
CORVIN_DEBUG=0
CORVIN_LOG_LEVEL=INFO
