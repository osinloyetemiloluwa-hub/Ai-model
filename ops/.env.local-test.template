# Corvin local-test environment template
#
# Copy this file to ops/.env.local-test and fill in the values below.
# ops/.env.local-test is gitignored — NEVER commit the filled-in file.
#
# Usage:
#   cp ops/.env.local-test.template ops/.env.local-test
#   docker compose -f ops/docker-compose.local-test.yml \
#                  --env-file ops/.env.local-test \
#                  up --build

# ── API keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=                # optional; leave empty if unused

# ── Bridge toggles ────────────────────────────────────────────────────────────
# Enable only the bridges you want to test.
# Each bridge requires a matching settings file under ops/local-test-data/bridge-settings/.
# Use SANDBOX bot tokens here — never paste production tokens.
CORVIN_BRIDGE_DISCORD=true
CORVIN_BRIDGE_TELEGRAM=false
CORVIN_BRIDGE_WHATSAPP=false
CORVIN_BRIDGE_SLACK=false
CORVIN_BRIDGE_EMAIL=false

# ── Gateway / Console UI ──────────────────────────────────────────────────────
# Enables the REST API + web console at http://localhost:18000
CORVIN_GATEWAY_ENABLED=true

# ── Tenant ────────────────────────────────────────────────────────────────────
CORVIN_TENANT_ID=_default

# ── Observability ─────────────────────────────────────────────────────────────
CORVIN_DEBUG=1
CORVIN_LOG_LEVEL=DEBUG

# ── Resource limits ───────────────────────────────────────────────────────────
CORVIN_MEM_LIMIT=2G
