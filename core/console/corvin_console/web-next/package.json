{
  "name": "corvin-console-web-next",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Corvin Console — re-launched frontend (Vite + React + TS + Tailwind + shadcn). See ADR-0037.",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:watch": "npm run build -- --watch",
    "type-check": "tsc -b",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:phase2": "vitest run tests/integration/phase2-critical-flows.test.tsx",
    "test:e2e": "playwright test",
    "test:security": "npm audit --audit-level=moderate && npm run lint",
    "test:all": "npm run type-check && npm run lint && npm run test:coverage && npm run test:phase2 && npm run test:e2e",
    "test:production": "npm run build && npm run test:all"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@tanstack/react-query": "^5.59.16",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.451.0",
    "mermaid": "^11.15.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.4",
    "reactflow": "^11.11.4",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "terser": "^5.47.1",
    "vis-network": "9.1.13",
    "zod": "^3.23.8"
  },
  "overrides": {
    "vitest": {
      "std-env": "4.1.0"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.8.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.12.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "happy-dom": "^20.9.0",
    "msw": "^2.14.6",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.8.1",
    "vite": "^6.4.3",
    "vitest": "^4.1.8"
  }
}
