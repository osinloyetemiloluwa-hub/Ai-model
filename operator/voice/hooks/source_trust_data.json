{
  "_about": "Static source-trust tier table for the Quiet Dialectic Layer (QDL). Hot-reload-fähig: edit and the next WebFetch/WebSearch picks up the change. Tiers describe how the LLM should *talk about* the source, not whether it can be reached. There is no allowlist or blocklist — every URL works; only the speech modulation differs. Domains are matched suffix-style: 'reuters.com' also matches 'www.reuters.com' and 'amp.reuters.com'.",
  "_tiers": {
    "green": "primary or established quality outlets, fact-checked, accountable corrections culture",
    "wiki": "Wikipedia & sister projects — reliable for established facts, weaker for current events",
    "neutral": "mainstream outlets with known editorial bias but generally factual",
    "yellow": "opinion-heavy, partisan, or single-source-driven; verifiable claims need second source",
    "red": "known disinformation / state propaganda / conspiracy / fabricated-news; high distancing",
    "satire": "humor / satire (Postillon, Onion); Jarvis must signal that explicitly"
  },
