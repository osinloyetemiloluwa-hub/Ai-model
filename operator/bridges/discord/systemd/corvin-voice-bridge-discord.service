[Unit]
Description=corvin-voice Discord bridge daemon
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=600
StartLimitBurst=3

[Service]
Type=simple
WorkingDirectory=__REPO_ROOT__/operator/bridges/discord
ExecStart=__NODE_BIN__ daemon.js
Restart=on-failure
RestartSec=60
TimeoutStopSec=20
StandardOutput=journal
StandardError=journal
EnvironmentFile=-%h/.config/corvin-voice/service.env

[Install]
WantedBy=default.target
