{
  "_NOTE": "Email bridge via IMAP (inbound) + SMTP (outbound). Use an app-specific password for Gmail / iCloud / Outlook etc. Whitelist contains sender email addresses (lowercase). Setup walkthrough: README -> Email bridge.",
  "_NOTE_chat_profiles": "Default is MAXIMUM OPEN (--dangerously-skip-permissions, all tools). To RESTRICT bot behaviour for individual senders, add a 'chat_profiles' object keyed by the sender email. Hot-reload applies immediately.",
  "imap_host": "imap.gmail.com",
  "imap_port": 993,
  "imap_secure": true,
  "imap_user": "you@example.com",
  "imap_password": "YOUR_IMAP_APP_PASSWORD",
  "imap_mailbox": "INBOX",
  "imap_poll_seconds": 30,
  "smtp_host": "smtp.gmail.com",
  "smtp_port": 465,
  "smtp_secure": true,
  "smtp_user": "you@example.com",
  "smtp_password": "YOUR_SMTP_APP_PASSWORD",
  "from_address": "you@example.com",
  "from_name": "Claude Bridge",
  "subject_prefix": "[Claude] ",
  "whitelist": [],
  "rate_limit_per_hour": 30,
  "pin": null,
  "_NOTE_security": "Inbound email is authenticated by DMARC/DKIM alignment (the From header alone is forgeable). A message is only trusted when the receiving provider's top Authentication-Results line shows dmarc=pass (or aligned dkim=pass) AND that line's authserv-id is provably the receiver's. With a well-known provider (Gmail/iCloud/Outlook/Yahoo/Mimecast/Proofpoint) it is auto-recognised; for a self-hosted / non-stamping IMAP provider you MUST set auth_results_authserv_id to your provider's authserv-id, otherwise an attacker could inject a forged Authentication-Results line. An empty whitelist DENIES all senders (use the PIN /auth flow to claim owner). Set dev_mode:true ONLY for local testing to restore legacy open behaviour.",
  "dev_mode": false,
  "auth_results_authserv_id": null
}
