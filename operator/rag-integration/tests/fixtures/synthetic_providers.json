{
  "providers": [
    {
      "id": "test-opensearch",
      "provider_id": "opensearch-local",
      "name": "OpenSearch Local",
      "description": "Local OpenSearch instance for testing",
      "author": "test-team",
      "version": "1.0.0",
      "endpoint": "http://localhost:9200/_search",
      "method": "POST",
      "auth_type": "basic",
      "auth_token_env_var": "OPENSEARCH_AUTH",
      "query_format_sample": "{\"query\": {\"match\": {\"content\": \"{query}\"}}, \"size\": {limit}}",
      "content_path": "hits.hits[].{content: _source.content, score: _score}",
      "score_path": "hits.hits[]._score",
      "metadata_path": "hits.hits[]._source",
      "source_url_path": "hits.hits[]._source.url",
      "capabilities": ["keyword-search", "filtering", "sorting"],
      "data_classification": "INTERNAL",
      "compliance_zone": "EU",
      "timeout_ms": 5000,
      "expected_fields": ["hits", "took", "timed_out"]
    },
    {
      "id": "test-qdrant",
      "provider_id": "qdrant-embeddings",
      "name": "Qdrant Vector DB",
      "description": "Qdrant vector database for semantic search",
      "author": "test-team",
      "version": "2.1.0",
      "endpoint": "http://localhost:6333/collections/documents/points/search",
      "method": "POST",
      "auth_type": "api-key",
      "auth_token_env_var": "QDRANT_API_KEY",
      "query_format_sample": "{\"vector\": [0.1, 0.2, 0.3], \"limit\": {limit}, \"with_payload\": true}",
      "content_path": "result[].payload.text",
      "score_path": "result[].score",
      "metadata_path": "result[].payload",
      "source_url_path": "result[].payload.source",
      "capabilities": ["semantic-search", "vector-search", "hybrid"],
      "data_classification": "INTERNAL",
      "compliance_zone": "EU",
      "timeout_ms": 3000,
      "expected_fields": ["result", "status"]
    },
    {
      "id": "test-elasticsearch",
      "provider_id": "elasticsearch-prod",
      "name": "Elasticsearch Production",
      "description": "Production Elasticsearch cluster",
      "author": "devops-team",
      "version": "8.0.0",
      "endpoint": "https://elasticsearch.prod.example.com/_search",
      "method": "POST",
      "auth_type": "bearer-token",
      "auth_token_env_var": "ELASTICSEARCH_TOKEN",
      "query_format_sample": "{\"query\": {\"multi_match\": {\"query\": \"{query}\", \"fields\": [\"title\", \"body\"]}}, \"size\": {limit}}",
      "content_path": "hits.hits[].{text: _source.body, relevance: _score}",
      "score_path": "hits.hits[]._score",
      "metadata_path": "hits.hits[]._source",
      "source_url_path": "hits.hits[]._source.url",
      "capabilities": ["full-text-search", "aggregations", "filtering"],
      "data_classification": "CONFIDENTIAL",
      "compliance_zone": "EU",
      "timeout_ms": 8000,
      "expected_fields": ["hits", "timed_out", "took"]
    },
    {
      "id": "test-postgres-json",
      "provider_id": "postgres-jsonb",
      "name": "PostgreSQL JSONB",
      "description": "PostgreSQL with JSONB document search",
      "author": "database-team",
      "version": "1.0.0",
      "endpoint": "http://api.db.local/search",
      "method": "POST",
      "auth_type": "bearer-token",
      "auth_token_env_var": "POSTGRES_API_TOKEN",
      "query_format_sample": "{\"search_term\": \"{query}\", \"limit\": {limit}, \"offset\": 0}",
      "content_path": "data[].document.content",
      "score_path": "data[].rank",
      "metadata_path": "data[].document",
      "source_url_path": "data[].document.source_url",
      "capabilities": ["full-text-search", "pagination", "filtering"],
      "data_classification": "INTERNAL",
      "compliance_zone": "EU",
      "timeout_ms": 4000,
      "expected_fields": ["data", "total_count"]
    },
    {
      "id": "test-milvus",
      "provider_id": "milvus-vectors",
      "name": "Milvus Vector Store",
      "description": "Milvus distributed vector database",
      "author": "ml-team",
      "version": "2.3.0",
      "endpoint": "http://milvus:19530/v1/search",
      "method": "POST",
      "auth_type": "none",
      "auth_token_env_var": null,
      "query_format_sample": "{\"collection_name\": \"documents\", \"vector\": [], \"limit\": {limit}, \"output_fields\": [\"content\", \"id\"]}",
      "content_path": "results[].entity.content",
      "score_path": "results[].distance",
      "metadata_path": "results[].entity",
      "source_url_path": null,
      "capabilities": ["vector-search", "similarity-matching"],
      "data_classification": "INTERNAL",
      "compliance_zone": "EU",
      "timeout_ms": 6000,
      "expected_fields": ["results", "status"]
    }
  ]
}
